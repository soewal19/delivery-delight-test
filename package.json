{
  "name": "delivery-delight",
  "version": "1.0.0",
  "description": "A full-stack food delivery application built with React (frontend) and NestJS (backend)",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "npm run start:backend",
    "start:backend": "cd backend && npm run start:prod",
    "start:frontend": "cd frontend && npm run preview",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm run test",
    "test:frontend": "cd frontend && npm run test",
    "test:e2e": "cd frontend && npx playwright test",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "setup": "bash scripts/setup.sh",
    "deploy": "bash scripts/deploy.sh",
    "vercel:dev": "vercel dev",
    "vercel:deploy": "vercel --prod",
    "vercel:login": "vercel login",
    "vercel:logout": "vercel logout",
    "vercel:whoami": "vercel whoami",
    "vercel:link": "vercel link",
    "vercel:env": "vercel env",
    "vercel:domains": "vercel domains",
    "vercel:alias": "vercel alias",
    "vercel:logs": "vercel logs",
    "vercel:inspect": "vercel inspect",
    "vercel:pull": "vercel pull",
    "vercel:push": "vercel push",
    "vercel:remove": "vercel remove",
    "vercel:rollback": "vercel rollback",
    "vercel:promote": "vercel promote",
    "vercel:env:add": "vercel env add",
    "vercel:env:rm": "vercel env rm",
    "vercel:env:ls": "vercel env ls",
    "vercel:domains:add": "vercel domains add",
    "vercel:domains:rm": "vercel domains rm",
    "vercel:domains:ls": "vercel domains ls",
    "vercel:alias:add": "vercel alias add",
    "vercel:alias:rm": "vercel alias rm",
    "vercel:alias:ls": "vercel alias ls"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "food-delivery",
    "react",
    "nestjs",
    "typescript",
    "full-stack"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@brave/brave-search-mcp-server": "^2.0.75",
    "@mokei/mcp-fetch": "^0.6.0",
    "@upstash/context7-mcp": "^2.1.6"
  }
}
